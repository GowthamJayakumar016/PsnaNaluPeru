@model List<Happy.DTOs.Admin.AdminBookingDto>

<h3 class="mb-4">Manage Bookings</h3>

<div class="card shadow">
    <div class="card-body">

        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>User</th>
                    <th>Room</th>
                    <th>Type</th>
                    <th>Check-In</th>
                    <th>Check-Out</th>
                    <th>Status</th>
                    <th style="width:220px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>@b.UserName</td>
                        <td>@b.RoomNumber</td>
                        <td>@b.RoomType</td>
                        <td>@b.CheckIn.ToShortDateString()</td>
                        <td>@b.CheckOut.ToShortDateString()</td>

                        <td>
                            @if (b.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                            else if (b.Status == "Confirmed")
                            {
                                <span class="badge bg-success">Confirmed</span>
                            }
                            else if (b.Status == "Cancelled")
                            {
                                <span class="badge bg-danger">Cancelled</span>
                            }
                            else if (b.Status == "Completed")
                            {
                                <span class="badge bg-secondary">Completed</span>
                            }
                        </td>

                        <td>
                            @if (b.Status == "Pending")
                            {
                                <a class="btn btn-success btn-sm me-1"
                                       href="/AdminBooking/Approve/@b.Id">
                                    Approve
                                </a>

                                <a class="btn btn-danger btn-sm"
                                       href="/AdminBooking/Reject/@b.Id">
                                    Reject
                                </a>
                            }

                            @if (b.Status == "Confirmed")
                            {
                                <a class="btn btn-warning btn-sm"
                                       href="/AdminBooking/Checkout/@b.Id">
                                    Check-Out
                                </a>
                            }

                            @if (b.Status == "Cancelled" || b.Status == "Completed")
                            {
                                <span class="text-muted">No Actions</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
   

</div>
