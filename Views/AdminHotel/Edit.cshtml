@model Happy.DTOs.Admin.AdminHotelEditDto

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Hotel details</h3>
    <a class="btn btn-outline-secondary btn-sm" href="/AdminRoom/Index">Back to rooms</a>
</div>

@if (TempData["HotelSavedMessage"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["HotelSavedMessage"]
    </div>
}

<div class="card shadow">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <label class="form-label">Hotel name</label>
            <input class="form-control mb-2" asp-for="Name" />

            <label class="form-label">Location</label>
            <input class="form-control mb-2" asp-for="Location" />

            <label class="form-label">Address</label>
            <input class="form-control mb-2" asp-for="Address" />

            <label class="form-label">Phone</label>
            <input class="form-control mb-2" asp-for="Phone" />

            <label class="form-label">Email</label>
            <input class="form-control mb-3" asp-for="Email" />

            <button class="btn btn-primary w-100" type="submit">Save</button>
        </form>
    </div>
</div>

