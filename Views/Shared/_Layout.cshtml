<!DOCTYPE html>
<html lang="en">
<head>
    <title>Happy Booking</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/Auth/Login">Happy Booking</a>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                @{
                    var role = Context.Session.GetString("UserRole");
                    var userId = Context.Session.GetString("UserId");
                }

                @if (!string.IsNullOrEmpty(userId))
                {
                    @if (role == "Admin")
                    {
                        <a class="btn btn-outline-light btn-sm" href="/AdminDashboard/Dashboard">Dashboard</a>
                        <a class="btn btn-outline-light btn-sm" href="/AdminHotel/Edit">Hotel details</a>
                        <a class="btn btn-outline-light btn-sm" href="/AdminBooking/Index">Bookings</a>
                        <a class="btn btn-outline-light btn-sm" href="/AdminRoom/Index">Rooms</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" href="/Dashboard/UserDashboard">Dashboard</a>
                        <a class="btn btn-outline-light btn-sm" href="/Hotel/Index">Hotels</a>
                        <a class="btn btn-outline-light btn-sm" href="/Booking/MyBookings">My Bookings</a>
                    }
                    <a class="btn btn-danger btn-sm" href="/Auth/Logout">Logout</a>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" href="/Auth/Login">Login</a>
                    <a class="btn btn-primary btn-sm" href="/Auth/Register">Register</a>
                }
            </div>
        </div>
    </nav>

    <div class="container mt-4 mb-5">
        @RenderBody()
    </div>
</body>
</html>
