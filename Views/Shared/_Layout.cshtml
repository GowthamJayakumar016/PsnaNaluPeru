<!DOCTYPE html>

<html>
<head>
    <title>Happy Booking</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Happy Booking</a>

            <div>
                @{
                    var role = Context.Session.GetString("UserRole");
                }

                @if (role == "Admin")
                {
                    <a class="btn btn-outline-light me-2" href="/AdminBooking/Index">Bookings</a>
                    <a class="btn btn-outline-light me-2" href="/AdminRoom/Index">Rooms</a>
                }
                else
                {
                    <a class="btn btn-outline-light me-2" href="/Hotel/Index">Hotels</a>
                    <a class="btn btn-outline-light me-2" href="/Booking/MyBookings">My Bookings</a>
                }

                <a class="btn btn-danger" href="/Auth/Logout">Logout</a>
            </div>
        </div>
    </nav>

    <!-- 🔥 IMPORTANT: THIS FIXES YOUR ERROR -->
    <div class="container mt-4">
        @RenderBody()
    </div>
    

</body>
</html>
